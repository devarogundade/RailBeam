# Copy to `.env` in this folder for `pnpm start:dev` / `nest start`.

# EVM private key for the x402 facilitator signer (0x-prefixed 32-byte hex). Required.
PRIVATE_KEY=

# CAIP-2 network id. Supported: eip155:16661 (0G mainnet), eip155:16602 (0G testnet).
X402_EVM_NETWORK=eip155:16661

# Optional JSON-RPC override for the facilitator signer (defaults from the chain definition).
# OG_RPC_URL=

# HTTP port (default 3402).
# PORT=3402
