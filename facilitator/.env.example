# Copy to `.env` in this folder for `pnpm start:dev` / `nest start`.

# EVM private key for the x402 facilitator signer (0x-prefixed 32-byte hex). Required.
PRIVATE_KEY=

# Comma-separated CAIP-2 network ids this process serves.
# Omit or leave empty to enable mainnet + testnet.
# Examples:
#   X402_EVM_NETWORKS=eip155:16661,eip155:16602
#   X402_EVM_NETWORKS=eip155:16602
# Supported: eip155:16661 (0G mainnet), eip155:16602 (0G testnet).
# X402_EVM_NETWORKS=eip155:16661,eip155:16602

# Optional JSON-RPC URLs (defaults: 0G public RPCs from chain metadata / BEAM_RPC).
# OG_RPC_URL_MAINNET=
# OG_RPC_URL_TESTNET=

# HTTP port (default 3402).
# PORT=3402
