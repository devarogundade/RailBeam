# Copy to `.env` for local Vite dev: `cp .env.example .env` (or copy manually on Windows).

# Stardorm Nest API (wallet auth, optional catalog when subgraph URL is unset).
VITE_STARDORM_API_URL=http://localhost:3000

# The Graph subgraph HTTP endpoint. When set, the app loads marketplace agents (and related
# on-chain data) from the indexer instead of GET /agents/catalog.
VITE_STARDORM_SUBGRAPH_URL=

# Optional. Decimals for payment amounts in the subgraph (default 18 if unset).
# VITE_STARDORM_PAYMENT_TOKEN_DECIMALS=18

# 0G — IdentityRegistry contract address (subscribe / unsubscribe in the UI).
# VITE_IDENTITY_REGISTRY_ADDRESS=0x...

# 0G — ReputationRegistry contract address (`giveFeedback` flows).
# VITE_REPUTATION_REGISTRY_ADDRESS=0x...

# Reown (WalletConnect) AppKit — https://dashboard.reown.com
# VITE_REOWN_PROJECT_ID=
