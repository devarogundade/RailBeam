{
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts", "eslint.config.cjs"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@beam/stardorm-api-contract": ["../packages/stardorm-api-contract/dist/index.mjs"],
      "@/*": ["./src/*"],
      "@stardorm/agentflow-finance/src/components/storage-image": [
        "./src/components/storage-image.tsx"
      ],
      "@stardorm/agentflow-finance/src/components/storage-image.tsx": [
        "./src/components/storage-image.tsx"
      ],
      "@stardorm/agentflow-finance/src/components/storage-file": [
        "./src/components/storage-file.tsx"
      ],
      "@stardorm/agentflow-finance/src/components/storage-file.tsx": [
        "./src/components/storage-file.tsx"
      ]
    }
  }
}
