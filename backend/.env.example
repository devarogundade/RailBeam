MONGODB_URI=
JWT_SECRET=
X402_FACILITATOR_URL=
STARDORM_SUBGRAPH_URL=
# Optional per-tier indexer URLs (used with `X-Beam-Chain-Id` from the app). Fallback: `STARDORM_SUBGRAPH_URL`.
STARDORM_SUBGRAPH_URL_MAINNET=
STARDORM_SUBGRAPH_URL_TESTNET=
PORT=
# Comma-separated browser origins (scheme + host + port). Must match the app URL exactly
# (e.g. http://localhost:5173 for Vite default, http://localhost:8080 if you use that port).
# Use * alone to allow any origin in development (reflects the request Origin; works with credentials).
CORS_ORIGINS=
PRIVATE_KEY=
OG_RPC_URL_MAINNET=
OG_RPC_URL_TESTNET=
# Chainscan-style API base (`.../open/api`) for `generate_tax_report`. Optional CHAINSCAN_API_URL overrides tier URLs.
# Otherwise: CHAINSCAN_API_URL_MAINNET if set, else CHAINSCAN_API_URL_TESTNET if set, else public mainnet default.
CHAINSCAN_API_URL=
CHAINSCAN_API_URL_MAINNET=
CHAINSCAN_API_URL_TESTNET=
# Optional USD price per 1 native (18 decimals) for rough tax math on native in/out only; leave unset for zero USD tax line.
CHAINSCAN_TAX_USD_PER_NATIVE=
STRIPE_SECRET_KEY=
# Signing secret from Stripe Dashboard → Developers → Webhooks (endpoint POST /webhooks/stripe).
# Enable events: checkout.session.completed, checkout.session.expired, checkout.session.async_payment_succeeded,
# checkout.session.async_payment_failed, identity.verification_session.* (created, processing, verified, requires_input, canceled).
STRIPE_WEBHOOK_SECRET=
APP_PUBLIC_URL=
# Optional: when set, funding a virtual card requires a successful native 0G transfer of at least
# (USD cents → wei) using `OG_NATIVE[tier].usdValue` from `beam-og.config.ts`, from the user's wallet to this address.
CREDIT_CARD_FUND_RECIPIENT=
# Must control CREDIT_CARD_FUND_RECIPIENT; used to send native 0G back to the user wallet on virtual card unfund.
CREDIT_CARD_TREASURY_PRIVATE_KEY=
ONRAMP_TREASURY_PRIVATE_KEY=
ONRAMP_RPC_URL_MAINNET=
ONRAMP_RPC_URL_TESTNET=
OG_STORAGE_INDEXER_RPC=
INFERENCE_USE_RESPONSES_API=