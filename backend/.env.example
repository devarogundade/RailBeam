MONGODB_URI=
JWT_SECRET=
# BullMQ email worker (Compose sets redis://redis:6379; local dev often redis://localhost:6378).
REDIS_URL=
# Gmail SMTP (use an App Password when 2FA is enabled).
SMTP_USER=
SMTP_PASS=
# Optional display/from address (defaults to SMTP_USER).
SMTP_FROM=
X402_FACILITATOR_URL=
# Per-tier indexer URLs (used with `X-Beam-Chain-Id` from the app).
STARDORM_SUBGRAPH_URL_MAINNET=
STARDORM_SUBGRAPH_URL_TESTNET=
PORT=
# Comma-separated browser origins (scheme + host, optional :port). Each entry prefix-matches
# (e.g. http://localhost allows http://localhost:5173 and http://localhost:8080).
# Use * alone to allow any origin in development (reflects the request Origin; works with credentials).
CORS_ORIGINS=
PRIVATE_KEY=
OG_RPC_URL_MAINNET=
OG_RPC_URL_TESTNET=
# Chainscan-style API base (`.../open/api`) for `generate_tax_report`.
# Set CHAINSCAN_API_URL and/or CHAINSCAN_API_URL_MAINNET / CHAINSCAN_API_URL_TESTNET.
CHAINSCAN_API_URL=
CHAINSCAN_API_URL_MAINNET=
CHAINSCAN_API_URL_TESTNET=
# Optional USD price per 1 native (18 decimals) for rough tax math on native in/out only; leave unset for zero USD tax line.
CHAINSCAN_TAX_USD_PER_NATIVE=
STRIPE_SECRET_KEY=
# Signing secret from Stripe Dashboard → Developers → Webhooks (endpoint POST /webhooks/stripe).
# Enable events: checkout.session.completed, checkout.session.expired, checkout.session.async_payment_succeeded,
# checkout.session.async_payment_failed, identity.verification_session.* (created, processing, verified, requires_input, canceled).
STRIPE_WEBHOOK_SECRET=
APP_PUBLIC_URL=
# Treasury for USDC.e x402 card funding (GET …/fund/access) and native unfund payouts on testnet.
CREDIT_CARD_FUND_RECIPIENT=
# Must control CREDIT_CARD_FUND_RECIPIENT; used for native 0G unfund on testnet only.
CREDIT_CARD_TREASURY_PRIVATE_KEY=
ONRAMP_TREASURY_PRIVATE_KEY=
ONRAMP_RPC_URL_MAINNET=
ONRAMP_RPC_URL_TESTNET=
OG_STORAGE_INDEXER_RPC=
INFERENCE_USE_RESPONSES_API=