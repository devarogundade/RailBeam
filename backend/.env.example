# Copy to `.env` in this folder for `pnpm start:dev` / `nest start`.

# MongoDB connection string (used by Mongoose).
MONGODB_URI=mongodb://127.0.0.1:27017/stardorm

# HS256 secret for issued JWTs (change in production).
JWT_SECRET=dev_secret_change_me

# The Graph — Stardorm subgraph HTTP URL (agent queries, validations, feedback).
STARDORM_SUBGRAPH_URL=

# HTTP port (default 3000).
# PORT=3000

# Comma-separated browser origins allowed for CORS. If empty, all origins are allowed.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# EVM private key (0x-prefixed hex) for 0G compute broker and storage uploads.
# Required when calling inference or storage features.
# PRIVATE_KEY=0x...

# 0G EVM JSON-RPC (optional). If unset, chosen from OG_EVM_NETWORK + defaults below.
# OG_RPC_URL=https://evmrpc.0g.ai

# Tier when OG_RPC_URL is unset: mainnet | testnet (default mainnet).
# OG_EVM_NETWORK=mainnet

# Optional per-tier overrides (otherwise defaults: mainnet https://evmrpc.0g.ai, testnet https://evmrpc-testnet.0g.ai).
# OG_RPC_URL_MAINNET=https://evmrpc.0g.ai
# OG_RPC_URL_TESTNET=https://evmrpc-testnet.0g.ai

# --- Stripe (on-ramp + Identity KYC) ---
# Use test keys on testnet / dev; live keys on mainnet production.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Public site URL for Checkout / Identity return_url (no trailing slash).
# APP_PUBLIC_URL=http://localhost:5173
# Treasury EVM key that holds on-ramp inventory (0x-prefixed hex). Required for fulfillment after Stripe confirms payment.
# ONRAMP_TREASURY_PRIVATE_KEY=0x...
# Optional RPC overrides for fulfillment (defaults follow 0G mainnet / testnet chain ids from CAIP-2).
# ONRAMP_RPC_URL_MAINNET=https://evmrpc.0g.ai
# ONRAMP_RPC_URL_TESTNET=https://evmrpc-testnet.0g.ai

# 0G storage indexer (defaults to https://indexer-storage-turbo.0g.ai if unset).
# OG_STORAGE_INDEXER_RPC=https://indexer-storage-turbo.0g.ai

# When `true`, use OpenAI-style `POST /v1/conversations` + `POST /v1/responses` for
# inference (no tools). When `false` or unset, use `POST .../chat/completions` only.
# Requires a provider that exposes those routes on the same base URL as chat completions.
# INFERENCE_USE_RESPONSES_API=true
